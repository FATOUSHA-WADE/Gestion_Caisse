# Environment Configuration - GESTICOM Backend
# Copiez ce fichier vers .env et configurez vos valeurs

# Nom de l'application
APP_NAME="Gestion_Caisse"

# URL de l'application
APP_URL=http://localhost:3000

# Configuration Base de données (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/caissedb

# Configuration JWT (Sécurisé - utilisez une clé aléatoire forte)
# Générez avec: openssl rand -base64 32
JWT_SECRET=lDlPqaWTaj5AZaM+BWOLYUa4B9mC52kD8ksG9dAnRC8=
JWT_EXPIRES_IN=8h

# Configuration SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=votre_email@gmail.com
