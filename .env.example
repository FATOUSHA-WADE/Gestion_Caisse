# Environment Configuration - GESTICOM Backend
# Copiez ce fichier vers .env et configurez vos valeurs

# Nom de l'application
APP_NAME="Gestion_Caisse"

# URL de l'application
APP_URL=http://localhost:3000

# Configuration Base de données (PostgreSQL)
# Pour développement local:
# DATABASE_URL=postgresql://user:password@localhost:5432/caissedb
# Pour Render: utilisez l'Internal Connection String du PostgreSQL Render
# (Render Dashboard > PostgreSQL > Connection Details > Internal Connection String)
# Format: postgres://user:password@hostname.render.com:5432/dbname?sslmode=require

# Configuration JWT (Sécurisé - utilisez une clé aléatoire forte)
# Générez avec: openssl rand -base64 32
JWT_SECRET=lDlPqaWTaj5AZaM+BWOLYUa4B9mC52kD8ksG9dAnRC8=
JWT_EXPIRES_IN=8h

# Configuration SMTP (Gmail) - CONFIGURATION OBLIGATOIRE POUR RECEVOIR LES EMAILS
# Suivez ces étapes pour configurer:
# 1. Gmail: Utilisez un "Mot de passe d'application" (et non votre mot de passe Gmail)
#    - Allez sur google.com > Sécurité > Validation en 2 étapes > Mots de passe d'application
# 2. Autres SMTP: Configurez votre serveur SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
# Créez un mot de passe d'application dans votre compte Google:
# https://myaccount.google.com/security > Validation en 2 étapes > Mots de passe d'application
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=votre_email@gmail.com
