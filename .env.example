# Configuration SMTP (Gmail) - CONFIGURATION OBLIGATOIRE POUR RECEVOIR LES EMAILS
# Suivez ces étapes pour configurer:
# 1. Gmail: Utilisez un "Mot de passe d'application" (et non votre mot de passe Gmail)
#    - Allez sur google.com > Sécurité > Validation en 2 étapes > Mots de passe d'application
# 2. Autres SMTP: Configurez votre serveur SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
# Créez un mot de passe d'application dans votre compte Google:
# https://myaccount.google.com/security > Validation en 2 étapes > Mots de passe d'application
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=votre_email@gmail.com
